{
  "appenders": {
    "console": {
      "type": "console"
    },
    "file": {
      "type": "file",
      "filename": "logs/pomelo.log",
      "maxLogSize": 10485760,
      "backups": 3
    }
  },
  "categories": {
    "default": {
      "appenders": ["console"],
      "level": "debug"
    },
    "log": {
      "appenders": ["console", "file"],
      "level": "info"
    }
  },
  "lineDebug": true,
  "replaceConsole": true
}
